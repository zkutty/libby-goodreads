# Goodreads RSS URL for your "Want to Read" shelf
# Format: https://www.goodreads.com/review/list_rss/{USER_ID}?shelf=to-read
GOODREADS_RSS=

# OverDrive/Libby library keys, comma-separated (the subdomain of each library's OverDrive page)
# e.g. if your library is at berkeleypubliclibrary.overdrive.com, the key is "berkeleypubliclibrary"
LIBRARY_KEYS=

# Telegram bot token from BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (send a message to your bot, then check getUpdates)
TELEGRAM_CHAT_ID=
